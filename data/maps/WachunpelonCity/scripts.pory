mapscripts WachunpelonCity_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: WachunpelonCity_OnTransition
}

script WachunpelonCity_OnTransition{
    setflag(FLAG_LANDMARK_WACHUNPELON)
    setflag(FLAG_SYS_DYNAMIC_LEVELS)
    end
}

script WachunpelonCity_EventScript_Mae{
    setflag(FLAG_SYS_BOSS_BATTLE)
    trainerbattle_single(TRAINER_MAE_3, WachunpelonCity_Text_Mae, "I'm a diva and I deserve this…", WachunpelonCity_EventScript_MaePostBattle)
    clearflag(FLAG_SYS_BOSS_BATTLE)
    msgbox("Yasss, this beach slayyyyys!\p
        No matter what you do, I'll\n
        never leave!\p
        I'm a DIVA!\n
        And I DESERVE this!", MSGBOX_NPC)
	end
}

script WachunpelonCity_EventScript_MaePostBattle{
    lock
    clearflag(FLAG_SYS_BOSS_BATTLE)
    msgbox("MAE: Usually this is the part where\n
        somebody would kick me out, right?\p
        But this time we're just on a beach.", MSGBOX_AUTOCLOSE)
    waitmessage
    playse(SE_PIN)
    applymovement(17, Common_Movement_ExclamationMark)
    delay(8)
    applymovement(17, Common_Movement_WalkInPlaceUp)
    waitmovement(0)
    waitse
    applymovement(17, WachunpelonCity_Movement_OldMan1)
    waitmovement(0)
    msgbox("OLD MAN: Excuse me!", MSGBOX_DEFAULT)
    waitmessage
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceDown)
    waitmovement(0)
    msgbox("Please don't battle here!\p
        My grandkids are playing on\n
        the beach! It's dangerous!\p
        If I worked here, I would have\n
        asked you to leave!", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(17, WachunpelonCity_Movement_OldMan2)
    waitmovement(0)
    msgbox("What's wrong with today's youth?\p
        Gosh… I hope my grandkids don't grow\n
        up and become like that…", MSGBOX_DEFAULT)
    waitmessage
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceUp)
    waitmovement(0)
    msgbox("MAE: …\n
        I'm still not leaving.", MSGBOX_AUTOCLOSE)
    waitmessage
    release
    end
}


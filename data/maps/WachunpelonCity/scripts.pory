    }
    while(var(VAR_RESULT) == NO){
        msgbox(WachunpelonCity_Text_PolicemanNo, MSGBOX_YESNO)
    }
    msgbox(WachunpelonCity_Text_Policeman2, MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(1, Common_Movement_WalkLeft)
    waitmovement(0)

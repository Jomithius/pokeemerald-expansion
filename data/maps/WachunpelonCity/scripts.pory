mapscripts WachunpelonCity_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: WachunpelonCity_OnTransition
}

script WachunpelonCity_OnTransition{
    setflag(FLAG_LANDMARK_WACHUNPELON)
    setflag(FLAG_SYS_DYNAMIC_LEVELS)
    end
}

script WachunpelonCity_EventScript_FatMan{
    msgbox("Man…\n
        That's a nice ocean breeze.", MSGBOX_SIGN)
    end
}

script WachunpelonCity_EventScript_OldMan{
    msgbox("This could be one of the last\n
        vacations we ever take! Hahaha!", MSGBOX_SIGN)
    end
}

script WachunpelonCity_EventScript_OldWoman{
    msgbox("Don't say that!", MSGBOX_SIGN)
    end
}

script WachunpelonCity_EventScript_AquaGrunt{
    delay(16)
    playse(SE_PIN)
    applymovement(VAR_LAST_TALKED, Common_Movement_ExclamationMark)
    waitmovement(0)
    waitse
    faceplayer
    msgbox("I'm not doing anything bad, I swear!\p
        I just moved out here after everything\n
        that happened.\p
        I just want to live quietly now.", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}


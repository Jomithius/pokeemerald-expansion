script WachunpelonCity_EventScript_AquaGrunt{
    delay(16)
    playse(SE_PIN)
    applymovement(VAR_LAST_TALKED, Common_Movement_ExclamationMark)
    waitmovement(0)
    waitse
    faceplayer
    msgbox("I'm not doing anything bad, I swear!\p
        I just moved out here after everything\n
        that happened.\p
        I just want to live quietly now.", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}


script WachunpelonCity_EventScript_Cook{
    lock
    msgbox("Hm… So he decided to use those spices…!\n
        Gosh… It's so yummy…\l
        Tasty…\l
        Scrumptious…\l
        Delicious…\l
        Savory…", MSGBOX_AUTOCLOSE)

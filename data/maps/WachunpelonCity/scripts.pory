    closedoor(46, 14)
    waitdooranim
    applymovement(OBJ_EVENT_ID_PLAYER, WachunpelonCity_Movement_PlayerEast)
    waitmovement(0)
    setflag(FLAG_HIDE_POLICEMAN_WACHUNPELON)
    setvar(VAR_SPEEDWAGON_STATE, 9)

mapscripts MtPyre_Exterior_Dave_House_MapScripts {}

script MtPyre_Exterior_Dave_House_EventScript_Gengar{
    lock
    faceplayer
    playmoncry(SPECIES_GENGAR, CRY_MODE_ENCOUNTER)
    waitmoncry
    release
    end
}


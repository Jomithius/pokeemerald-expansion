script MtPyre_Exterior_Dave_House_EventScript_Dave{
    lock
    faceplayer
    goto_if_unset(FLAG_RECEIVED_FANTASIA, MtPyre_Exterior_Dave_House_EventScript_GiveFantasia)
    msgbox("If we have to battle in the\n
        future, do me a favor and lose, okay?", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}

script MtPyre_Exterior_Dave_House_EventScript_GiveFantasia{
    lock
    bufferleadmonspeciesname(STR_VAR_1)
    msgbox(MtPyre_Exterior_Dave_House_Text_Fantasia, MSGBOX_DEFAULT)
    waitmessage
    giveitem(ITEM_FANTASIA)
    waitmessage
    msgbox(MtPyre_Exterior_Dave_House_Text_WarnFantasia, MSGBOX_AUTOCLOSE)
    waitmessage
    setflag(FLAG_RECEIVED_FANTASIA)
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end

}

text MtPyre_Exterior_Dave_House_Text_Fantasia{
    "Oh. Yes, hello.\n
    Who are you?\l
    … … … …\p
    Oh. Nice to meet you, {PLAYER}.\n
    I'm DAVE, a member of the ELITE FOUR.\p
    So?\n
    Why'd you come all the way out here?\p
    … … … …\p
    Oh, I see.\p
    Well, I can tell you're a good TRAINER.\n
    Your {STR_VAR_1} looks strong.\p
    Usually I sell these, but I'll give you\n
    one for free.\p
    There's a guy that recently bought out\n
    almost all my stock, so I'm feeling\l
    generous today."
}

text MtPyre_Exterior_Dave_House_Text_WarnFantasia{
    "{COLOR BLUE}{SHADOW LIGHT_BLUE}To see the effect of FANTASIA, you\n
    need to reload your character.\p
    This can be done by entering or exiting\n
    a new map, such as a building or cave.\l
    Check the README for more details.\p
    {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}DAVE: If we have to battle in the\n
    future, do me a favor and lose, okay?"
}

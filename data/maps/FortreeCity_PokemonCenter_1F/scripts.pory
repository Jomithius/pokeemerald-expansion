raw`.set LOCALID_NURSE, 1

FortreeCity_PokemonCenter_1F_MapScripts::
	map_script MAP_SCRIPT_ON_TRANSITION, FortreeCity_PokemonCenter_1F_OnTransition
	map_script MAP_SCRIPT_ON_RESUME, CableClub_OnResume
	.byte 0

FortreeCity_PokemonCenter_1F_OnTransition:
	setrespawn HEAL_LOCATION_FORTREE_CITY
	end

FortreeCity_PokemonCenter_1F_EventScript_Nurse::
	setvar VAR_0x800B, LOCALID_NURSE
	call Common_EventScript_PkmnCenterNurse
	waitmessage
	waitbuttonpress
	release
	end

FortreeCity_PokemonCenter_1F_EventScript_Gentleman::
	msgbox FortreeCity_PokemonCenter_1F_Text_GoToSafariZone, MSGBOX_NPC
	end

FortreeCity_PokemonCenter_1F_EventScript_Man::
	msgbox FortreeCity_PokemonCenter_1F_Text_RecordCornerIsNeat, MSGBOX_NPC
	end

FortreeCity_PokemonCenter_1F_EventScript_Boy::
	msgbox FortreeCity_PokemonCenter_1F_Text_DoYouKnowAboutPokenav, MSGBOX_NPC
	end

FortreeCity_PokemonCenter_1F_Text_GoToSafariZone:
	.string "Listen, kid, are you working\n"
	.string "on a POKéDEX?\p"
	.string "Hmm… Go to the SAFARI ZONE.\n"
	.string "That's my suggestion.$"

FortreeCity_PokemonCenter_1F_Text_RecordCornerIsNeat:
	.string "Have you done anything at\n"
	.string "the RECORD CORNER?\p"
	.string "It's pretty neat. It mixes and matches\n"
	.string "the records of TRAINERS.\p"
	.string "I don't know quite how it works,\n"
	.string "but it's cool. It's exciting, even!$"

FortreeCity_PokemonCenter_1F_Text_DoYouKnowAboutPokenav:
	.string "Oh, wow, you have a POKéNAV!\n"
	.string "And it's just like mine!\p"
	.string "Do you know about POKéNAV's\n"
	.string "MATCH CALL system?\p"
	.string "Access it, and you can chat with\n"
	.string "registered TRAINERS anytime.\p"
	.string "It also shows you which TRAINERS\n"
	.string "want a rematch with you.\p"
	.string "It's really nifty! Those DEVON guys\n"
	.string "sure know what they're doing!$"

`

script FortreeCity_PokemonCenter_1F_EventScript_RoostTutor{
    lock
	faceplayer
    msgbox(FortreeCity_PokemonCenter_1F_Text_RoostTeach, MSGBOX_YESNO)
	waitmessage
    goto_if_eq(VAR_RESULT, NO, MoveTutor_EventScript_RoostDeclined)
	msgbox("Which POKéMON do you want to\nteach ROOST to?", MSGBOX_DEFAULT)
	setvar(VAR_0x8005, MOVE_ROOST)
	call(MoveTutor_EventScript_OpenPartyMenu)
	goto_if_eq(VAR_RESULT, 0, MoveTutor_EventScript_RoostDeclined)
	goto(MoveTutor_EventScript_RoostTaught)
	end
}

script MoveTutor_EventScript_RoostDeclined{
	msgbox("Well, alright.\n
		Come back if you have more birds.", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

script MoveTutor_EventScript_RoostTaught{
	msgbox("All right!\p
		Come back if you have more birds!", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

text FortreeCity_PokemonCenter_1F_Text_RoostTeach{
	"It's important for birds to be able to\n
    rest properly!\p
    If you have a bird POKéMON, I can teach\n
    it how to ROOST."
}

script FortreeCity_PokemonCenter_1F_EventScript_FangsTutor{
	lock
	faceplayer
	msgbox("They call me the MAD DOG!\p
		If you want, I can teach your\n
		dogs how to get MAD!", MSGBOX_YESNO)
	waitmessage
	goto_if_eq(VAR_RESULT, YES, FortreeCity_PokemonCenter_1F_EventScript_FangsTutorChoices)
	goto(FortreeCity_PokemonCenter_1F_EventScript_FangsTutorDecline)
	release
	end
}

script FortreeCity_PokemonCenter_1F_EventScript_FangsTutorChoices{
	lock
	msgbox("What move do you want me\nto teach?", MSGBOX_DEFAULT)
	dynmultichoice(0,0, FALSE, 6, 0, DYN_MULTICHOICE_CB_NONE, "FIRE FANG", "ICE FANG", "THUNDER FANG", "POISON FANG", "PSYCHIC FANGS")
	switch (var(VAR_RESULT)) {
		case 0:
			goto(MoveTutor_EventScript_FireFangTeach)
		case 1:
			goto(MoveTutor_EventScript_IceFangTeach)
		case 2:
			goto(MoveTutor_EventScript_ThunderFangTeach)
		case 3:
			goto(MoveTutor_EventScript_PoisonFangTeach)
		case 4:
			goto(MoveTutor_EventScript_PsychicFangsTeach)
		case MULTI_B_PRESSED:
			goto(FortreeCity_PokemonCenter_1F_EventScript_FangsTutorDecline)
		default:
			goto(FortreeCity_PokemonCenter_1F_EventScript_FangsTutorDecline)
	}
	end
}

script MoveTutor_EventScript_FireFangTeach{
	msgbox("Which dog do you want to\nteach FIRE FANG to?", MSGBOX_DEFAULT)
	setvar(VAR_0x8005, MOVE_FIRE_FANG)
	call(MoveTutor_EventScript_OpenPartyMenu)
	goto_if_eq(VAR_RESULT, 0, FortreeCity_PokemonCenter_1F_EventScript_FangsTutorDecline)
	goto(FortreeCity_PokemonCenter_1F_EventScript_FangsTutorTaught)
	end
}


script FortreeCity_PokemonCenter_1F_EventScript_FangsTutorDecline{
	lock
	msgbox("Grrr…", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

script FortreeCity_PokemonCenter_1F_EventScript_FangsTutorTaught{
	lock
	msgbox("Awooohooo!\p
		Come back if you\n
		have more MAD DOGS!", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

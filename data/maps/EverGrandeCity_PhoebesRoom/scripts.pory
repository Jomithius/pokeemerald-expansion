script EverGrandeCity_PhoebesRoom_EventScript_EugeniaDefeated{
    setflag(FLAG_DEFEATED_ELITE_4_PHOEBE)
    setvar(VAR_LINA_TALKED_TO, 3)
	applymovement(OBJ_EVENT_ID_FOLLOWER, Common_Movement_EnterPokeball)
    waitmovement(0)
    callnative(RemoveFollowingPokemon)
    setflag(FLAG_TEMP_E)
    clearflag(FLAG_SAFE_FOLLOWER_MOVEMENT)
	call(PokemonLeague_EliteFour_SetAdvanceToNextRoomMetatiles)
	msgbox(EverGrandeCity_PhoebesRoom_Text_EugeniaPostBattleSpeech, MSGBOX_DEFAULT)
	release
	end
}

script EverGrandeCity_PhoebesRoom_EventScript_EugeniaPostBattleSpeech{
    applymovement(VAR_LAST_TALKED, EverGrandeCity_PhoebesRoom_Movement_FaceAwayPlayer)
    waitmovement(0)
    msgbox(EverGrandeCity_PhoebesRoom_Text_EugeniaPostBattleSpeech, MSGBOX_DEFAULT)
    release
    end
}

script EliteFour_EventScript_PlayerGetsInPositionEugeniaBattle{
    applymovement(2, Common_Movement_EnterPokeball)
    waitmovement(2)
    removeobject(2)
	specialvar(VAR_RESULT, GetPlayerFacingDirection)
	switch (var(VAR_RESULT)) {
        case DIR_NORTH:
            applymovement(OBJ_EVENT_ID_PLAYER, EverGrandeCity_SidneysRoom_Movement_PlayerGetsInPositionNorth)
			waitmovement(0)
			break
        case DIR_SOUTH:
			applymovement(OBJ_EVENT_ID_PLAYER, EverGrandeCity_SidneysRoom_Movement_PlayerGetsInPositionSouth)
			delay(8)
			applymovement(VAR_LAST_TALKED, Common_Movement_WalkInPlaceDown)
			waitmovement(OBJ_EVENT_ID_PLAYER)
			break
        case DIR_WEST:
			applymovement(OBJ_EVENT_ID_PLAYER, EverGrandeCity_SidneysRoom_Movement_PlayerGetsInPositionWest)
			delay(8)
			applymovement(VAR_LAST_TALKED, Common_Movement_WalkInPlaceDown)
			waitmovement(OBJ_EVENT_ID_PLAYER)
			break
        default:
            applymovement(OBJ_EVENT_ID_PLAYER, EverGrandeCity_SidneysRoom_Movement_PlayerGetsInPositionNorth)
			waitmovement(0)
    }
	clearflag(FLAG_TEMP_E)
	callnative(UpdateFollowingPokemon)
    playse(SE_BALL_OPEN)
    fadescreen(FADE_TO_WHITE)
    waitse
    applymovement(OBJ_EVENT_ID_FOLLOWER, Common_Movement_ExitPokeball)
    waitmovement(0)
    applymovement(OBJ_EVENT_ID_FOLLOWER, BaldesianForestDojo_Movement_FollowerBesidePlayer)
    waitmovement(0)
	fadescreen(FADE_FROM_WHITE)
    msgbox("Hmph! I'm going to do everything I\n
        can to make you pay!", MSGBOX_AUTOCLOSE)
    waitmessage
    playse(SE_BALL_OPEN)
    fadescreen(FADE_TO_WHITE)
    waitse
    clearflag(FLAG_HIDE_RAYQUAZA_PHOEBES_ROOM)
    addobject(LOCALID_RAYQUAZA)
	fadescreen(FADE_FROM_WHITE)
    delay(30)
    playse(SE_PIN)
    applymovement(OBJ_EVENT_ID_FOLLOWER, Common_Movement_ExclamationMark)
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_ExclamationMark)
    waitmovement(0)
    waitse
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, EverGrandeCity_PhoebesRoom_Movement_PlayerStepBack)
    delay(8)
    applymovement(OBJ_EVENT_ID_FOLLOWER, EverGrandeCity_PhoebesRoom_Movement_PlayerStepBack)
	applymovement(LOCALID_RAYQUAZA, EverGrandeCity_Movement_EliteFourPokemonGetsInPosition)
    waitmovement(LOCALID_RAYQUAZA)
    delay(30)
	applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceLeft)
    delay(8)
    applymovement(OBJ_EVENT_ID_FOLLOWER, Common_Movement_WalkInPlaceRight)
    waitmovement(0)
    delay(60)
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceUp)
    delay(8)
    applymovement(OBJ_EVENT_ID_FOLLOWER, Common_Movement_WalkInPlaceUp)
    waitmovement(0)
	applymovement(OBJ_EVENT_ID_FOLLOWER, EverGrandeCity_Movement_PlayerPokemonGetsInPosition)
	waitmovement(0)
	delay(30)
	return
}


text EverGrandeCity_PhoebesRoom_Text_IntroSpeechVar2{
    "Wha-!\n
    Oh, it's you again.\p
    Let's get this over with so I can\n
    go back to reading. Hmph!"
}

text EverGrandeCity_PhoebesRoom_Text_LinaStillGoingIntoHouses{
    "Wha-!\n
    You again?!\p
    Right when I was getting to\n
    the good part!\p
    I thought I locked the door this time…\n
    but you'd probably break in either way.\p
    Are you still going into random peoples'\n
    houses?"
}

text EverGrandeCity_PhoebesRoom_Text_LinaDidYouTakeEevee{
    "Hmph! Of course you are.\p
    They still haven't found my EEVEE,\n
    by the way…\p
    So be honest.\n
    Was it you?"
}

text EverGrandeCity_PhoebesRoom_Text_LinaReally{
    "…\p
    Really?"
}

text EverGrandeCity_PhoebesRoom_Text_EugeniaIntro{
    "You little-\n
    What the fuck is wrong with you?!\l
    Didn't your mother raise you better?!\p
    You should know it's wrong to steal!\n
    I'm going to crush you, you dirty thief!"
}

text EverGrandeCity_PhoebesRoom_Text_EugeniaDefeat{
    ">.>\n
    Hmph!"
}

text EverGrandeCity_PhoebesRoom_Text_EugeniaPostBattleSpeech{
    "Get out of my sight!\n
    Hmph!"
}

text EverGrandeCity_PhoebesRoom_Text_LinaNo{
    "Hmph. Oh well.\p
    Let's get this over with so I\n
    can get back to my book."
}

script EverGrandeCity_PhoebesRoom_EventScript_Luxray{
	lock
	faceplayer
	playmoncry(SPECIES_LUXRAY, CRY_MODE_ENCOUNTER)
	delay(24)
	applymovement(2, Common_Movement_FaceOriginalDirection)
    waitmovement(2)
	release
	end
}

movement EverGrandeCity_PhoebesRoom_Movement_PlayerStepBack{
    lock_facing_direction
    walk_fast_down
    unlock_facing_direction
}

movement EverGrandeCity_PhoebesRoom_Movement_FaceAwayPlayer{
    face_away_player
}

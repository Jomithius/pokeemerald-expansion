script MossdeepCity_EventScript_PunchesTutorDecline{
	lock
	msgbox("I see.\p
		Come back if you want to teach your\n
		POKéMON the way of the elemental fist.", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

script MossdeepCity_EventScript_PunchesTutorTaught{
	lock
	msgbox("Come back if you want to teach more\n
		POKéMON the way of the elemental fist.", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

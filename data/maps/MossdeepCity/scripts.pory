MossdeepCity_EventScript_Man::
	lock
	faceplayer
	msgbox MossdeepCity_Text_SurfExhilarating, MSGBOX_DEFAULT
	applymovement VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection
	waitmovement 0
	release
	end

MossdeepCity_EventScript_KingsRockBoy::
	lock
	faceplayer
	goto_if_set FLAG_RECEIVED_KINGS_ROCK, MossdeepCity_EventScript_ReceivedKingsRock
	msgbox MossdeepCity_Text_WantKingsRockStevenGaveMe, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, NO, MossdeepCity_EventScript_DeclineKingsRock
	msgbox MossdeepCity_Text_YouCanKeepIt, MSGBOX_DEFAULT
	giveitem ITEM_KINGS_ROCK
	goto_if_eq VAR_RESULT, FALSE, Common_EventScript_ShowBagIsFull
	setflag FLAG_RECEIVED_KINGS_ROCK
	release
	end

MossdeepCity_EventScript_ReceivedKingsRock::
	msgbox MossdeepCity_Text_StevensHouseOverThere, MSGBOX_DEFAULT
	release
	end

MossdeepCity_EventScript_DeclineKingsRock::
	msgbox MossdeepCity_Text_WhatToDoWithWeirdRock, MSGBOX_DEFAULT
	release
	end

MossdeepCity_EventScript_BlackBelt::
	msgbox MossdeepCity_Text_SootopolisNewGymLeader, MSGBOX_NPC
	end

MossdeepCity_EventScript_Scott::
	lock
	faceplayer
	msgbox MossdeepCity_Text_ScottSomethingWrongWithTown, MSGBOX_DEFAULT
	closemessage
	call_if_eq VAR_FACING, DIR_NORTH, MossdeepCity_EventScript_ScottExitNorth
	call_if_eq VAR_FACING, DIR_EAST, MossdeepCity_EventScript_ScottExitEast
	addvar VAR_SCOTT_STATE, 1
	removeobject LOCALID_SCOTT
	release
	end

MossdeepCity_EventScript_ScottExitNorth::
	applymovement OBJ_EVENT_ID_PLAYER, MossdeepCity_Movement_PlayerWatchScottExit
	applymovement LOCALID_SCOTT, MossdeepCity_Movement_ScottExitNorth
	waitmovement 0
	return

MossdeepCity_EventScript_ScottExitEast::
	applymovement OBJ_EVENT_ID_PLAYER, MossdeepCity_Movement_PlayerWatchScottExit
	applymovement LOCALID_SCOTT, MossdeepCity_Movement_ScottExitEast
	waitmovement 0
	return

MossdeepCity_Movement_PlayerWatchScottExit:
	delay_16
	delay_16
	walk_in_place_faster_left
	step_end

MossdeepCity_Movement_ScottExitNorth:
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	step_end

MossdeepCity_Movement_ScottExitEast:
	walk_down
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	walk_left
	step_end

MossdeepCity_Text_WantKingsRockStevenGaveMe:
	.string "I got this from STEVEN, but I don't\n"
	.string "know what it's good for.\p"
	.string "I think it's called KING'S ROCK.\n"
	.string "Do you want it?$"

MossdeepCity_Text_YouCanKeepIt:
	.string "Why would you want it?\n"
	.string "You're weird.\p"
	.string "You can keep it, but keep it a secret\n"
	.string "from STEVEN.$"

MossdeepCity_Text_StevensHouseOverThere:
	.string "STEVEN's house is right over there!$"

MossdeepCity_Text_WhatToDoWithWeirdRock:
	.string "Yeah, you think so, too! What are you\n"
	.string "supposed to do with some weird rock?$"

MossdeepCity_Text_WailmerWatching:
	.string "The GYM LEADER here wears a\n"
	.string "real suit of armor!\p"
	.string "My Mom said they have to wear it\n"
	.string "to protect their glass bones!\p"
	.string "Hahaha! How can they train\n"
	.string "so much with glass bones?$"

MossdeepCity_Text_SpaceCenterReceivedLetter:
	.string "The island's SPACE CENTER has been\n"
	.string "launching huge rockets.\p"
	.string "There's been some kind of an uproar\n"
	.string "over a letter they received recently.$"

MossdeepCity_Text_SpaceCenterLaunchingRockets:
	.string "The island's SPACE CENTER has been\n"
	.string "launching huge rockets.$"

MossdeepCity_Text_MossdeepTargetedByMagma:
	.string "I heard from a SAILOR buddy that\n"
	.string "TEAM AQUA set up shop in LILYCOVE.\p"
	.string "I also heard that someone came along\n"
	.string "and wiped the floor with them!\p"
	.string "But MOSSDEEP here's been targeted\n"
	.string "by that TEAM MAGMA.\p"
	.string "If you want to know what they're up to,\n"
	.string "go visit the SPACE CENTER.$"

MossdeepCity_Text_FeelReliefOnLand:
	.string "I'm a SAILOR, so the sea's obviously\n"
	.string "more important to me.\p"
	.string "But you know? When I get back on land\n"
	.string "after a long voyage, I do feel relief!$"

MossdeepCity_Text_NiceIfWorldCoveredByFlowers:
	.string "Wouldn't it be nice?\p"
	.string "If the whole world was covered in\n"
	.string "plants and flowers like this island?$"

MossdeepCity_Text_LifeNeedsSeaToLive:
	.string "All life needs the sea to live, even\n"
	.string "though it makes its home on the land.\p"
	.string "Life, having run its course, becomes\n"
	.string "soil and returns to the land.\p"
	.string "And the sea is always connected to\n"
	.string "the land.\p"
	.string "Yes, like the very shoreline here.$"

MossdeepCity_Text_SurfExhilarating:
	.string "A voyage on a ship is fine.\p"
	.string "But crossing the sea with POKéMON\n"
	.string "using SURF…\p"
	.string "Now that's an exhilarating trip!\n"
	.string "Wouldn't you agree, youngster?$"

MossdeepCity_Text_SpecialSpaceCenterRock:
	.string "This rock has a special meaning to\n"
	.string "the people at the SPACE CENTER.\p"
	.string "They put it here as their wish for\n"
	.string "their rockets to fly safely.\p"
	.string "When you make a wish, what do you use?\n"
	.string "Do you wish upon a star?\p"
	.string "I use a wish tag to make it happen.\n"
	.string "That's what I do.$"

MossdeepCity_Text_ItsAWhiteRock:
	.string "It's a white rock.$"

MossdeepCity_Text_GymSign:
	.string "MOSSDEEP CITY POKéMON GYM\n"
	.string "LEADERS: MOMO & ARIA\p"
	.string "“The bald NINJA and KNIGHT\n"
	.string "of the SACRED BLADE!”$"

MossdeepCity_Text_CitySign:
	.string "MOSSDEEP CITY\n"
	.string "“Our slogan: Cherish POKéMON!”$"

MossdeepCity_Text_SpaceCenterSign:
	.string "MOSSDEEP SPACE CENTER\n"
	.string "“The closest place to space.”$"

MossdeepCity_Text_ScottSomethingWrongWithTown:
	.string "SCOTT: {PLAYER}{KUN}, feeling good?\n"
	.string "I'm doing great!\p"
	.string "I'd heard MOSSDEEP's GYM LEADER is\n"
	.string "pretty strong, so I decided to come\l"
	.string "take a look-see for myself.\p"
	.string "But there's something wrong about\n"
	.string "this town.\p"
	.string "People are going on about a warning\n"
	.string "letter and the SPACE CENTER…\p"
	.string "I don't think it concerns me in any\n"
	.string "way, though.$"

MossdeepCity_Text_SootopolisNewGymLeader:
	.string "Ahh… It feels great letting the waves\n"
	.string "wash over my feet…\p"
	.string "Speaking of the waves, you know that\n"
	.string "island city SOOTOPOLIS?\p"
	.string "I think the GYM there had a new\n"
	.string "LEADER come in.\p"
	.string "People tell me they always say\n"
	.string "“yeah” and “yeet”.$"

`

script MossdeepCity_EventScript_Momo{
	lock
	faceplayer
	goto_if_not_defeated(TRAINER_MOMO, MossdeepCity_EventScript_MomoBattle)
	msgbox("{PLAYER}, if you're going to see ARIA\n
		can you tell them to hurry up and\l
		finish their training?", MSGBOX_AUTOCLOSE)
	release
	end
}

script MossdeepCity_EventScript_MomoBattle{
	msgbox("Hi, {PLAYER}.\n
		ARIA's… not here.\p
		They're training on the beach\n
		right now.\l
		…\l
		…\p
		Did you want to battle?", MSGBOX_YESNO)
	waitmessage
	if(var(VAR_RESULT) == NO){
		msgbox("… Okay.", MSGBOX_AUTOCLOSE)
		waitmessage
	}
	else{
		msgbox("Okay.\p
			I… want to show you the new\n
			ninjutsu I've been working on.", MSGBOX_AUTOCLOSE)
		waitmessage
		fadeoutbgm(0)
		delay(24)
		playse(SE_ARENA_TIMEUP1)
		delay(16)
		playse(SE_ARENA_TIMEUP1)
		waitse
		playse(SE_ARENA_TIMEUP2)
		waitse
		playse(SE_M_PETAL_DANCE)
		fadescreenspeed(FADE_TO_WHITE, 4)
		waitse
		clearflag(FLAG_HIDE_MOMO_SHADOW_CLONE_MOSSDEEP)
		addobject(20)
		call(MossdeepCity_EventScript_MomoShadowClone)
		fadescreenspeed(FADE_FROM_WHITE, 3)
		delay(20)
		playbgm(MUS_KIMONO_DANCE, FALSE)
		msgbox("I can make clones now.\n
			Isn't that cool?\p
			…\n
			Okay, let's battle.", MSGBOX_AUTOCLOSE)
		waitmessage
		trainerbattle_two_trainers(TRAINER_MOMO, "Everyone's so mean to me…", TRAINER_SHADOW_CLONE_MOMO, "</3")
		msgbox("I… lost again.\n
			Still, I had fun.\p
			{PLAYER}, if you're going to see ARIA,\n
			can you tell them to hurry up and\l
			finish their training?", MSGBOX_AUTOCLOSE)
		waitmessage
		addvar(VAR_GYM_LEADER_COUNT, 1)
		goto_if_eq(VAR_GYM_LEADER_COUNT, 9, EventScript_UnlockEliteFourFinalRematch)
		release
		end
	}
}

script MossdeepCity_EventScript_MomoShadowClone{
	getplayerxy(VAR_TEMP_2, VAR_TEMP_4)
	if(var(VAR_TEMP_2) == 37 && var(VAR_TEMP_4) == 10){
		applymovement(20, MossdeepCity_Movement_MomoClone)
	}
	elif(var(VAR_TEMP_2) == 39 && var(VAR_TEMP_4) == 10){
		applymovement(20, MossdeepCity_Movement_MomoClone2)
	}
	else{
		applymovement(20, Common_Movement_FaceDown)
	}
	waitmovement(20)
	return
}

script MossdeepCity_EventScript_Aria{
	lock
	goto_if_not_defeated(TRAINER_ARIA, MossdeepCity_EventScript_AriaBattle)
	goto_if_unset(FLAG_RECEIVED_TOTODILE_PARTNER, MossdeepCity_EventScript_GiveTotodile)
	playse(SE_M_DOUBLE_TEAM)
    waitse
    playmoncry(SPECIES_ETERNATUS, CRY_MODE_NORMAL)
    msgbox("ARGH!\n
        AAAARGH!", MSGBOX_DEFAULT)
    waitmessage
    waitmoncry
	msgbox("They're busy training.\n
		Probably shouldn't bother them again.", MSGBOX_SIGN)
	waitmessage
	release
	end
}

script MossdeepCity_EventScript_AriaBattle{
	lock
    getobjectfacingdirection(OBJ_EVENT_ID_PLAYER, VAR_TEMP_1)
    playbgm(MUS_NONE, FALSE)
    delay(20)
    playse(SE_M_DOUBLE_TEAM)
    waitse
    playmoncry(SPECIES_ETERNATUS, CRY_MODE_NORMAL)
    msgbox("ARGH!\n
        AAAARGH!", MSGBOX_AUTOCLOSE)
    waitmessage
    waitmoncry
    playse(SE_PIN)
    applymovement(21, Common_Movement_ExclamationMark)
    waitmovement(21)
    waitse
	setobjectnewmovementtype(21, MOVEMENT_TYPE_NONE)
    applymovement(21, Common_Movement_FacePlayer)
    waitmovement(21)
    delay(40)
    //playse(SE_M_YAWN)
	playmoncry(SPECIES_TERAPAGOS, CRY_MODE_NORMAL)
    call(ShoalCave_LowTideIceRoom_EventScript_AriaPosition1)
    waitmovement(21)
    msgbox("AH!", MSGBOX_AUTOCLOSE)
    waitmessage
	waitmoncry
	playbgm(MUS_ENCOUNTER_COOL, FALSE)
    call(ShoalCave_LowTideIceRoom_EventScript_AriaPosition2)
    waitmovement(21)
	msgbox("{PLAYER}!\n
		You scared me!\p
		Wait…\n
		This murderous intent…!\p
		I see…\n
		So you would challenge this KNIGHT?\p
		All right! I'll show you the power of\n
		the SACRED BLADE!", MSGBOX_AUTOCLOSE)
	waitmessage
	trainerbattle_no_intro(TRAINER_ARIA, "M-My lord…")
	msgbox("ARRGGGHH!\n
		I lost again!", MSGBOX_DEFAULT)
	waitmessage
	addvar(VAR_GYM_LEADER_COUNT, 1)
	checkitem(ITEM_SACRED_BLADE)
	goto_if_eq(VAR_RESULT, TRUE, MossdeepCity_EventScript_GiveTotodilePostBattle)
	msgbox("I need to train more!\p
		{PLAYER}, if you're going to see MOMO,\n
		can you tell her I'm gonna train for\l
		a while longer?", MSGBOX_AUTOCLOSE)
	waitmessage
	setobjectnewmovementtype(21, MOVEMENT_TYPE_WALK_IN_PLACE_DOWN)
	applymovement(21, Common_Movement_WalkInPlaceDown)
	waitmovement(21)
	goto_if_eq(VAR_GYM_LEADER_COUNT, 9, EventScript_UnlockEliteFourFinalRematch)
	release
	end
}

script MossdeepCity_EventScript_GiveTotodilePostBattle{
	lock
	closemessage
	playse(SE_PIN)
    applymovement(21, Common_Movement_ExclamationMark)
    waitmovement(21)
    waitse
	msgbox("Wait…\n
		This power I sense…!\p
		{PLAYER}, are you also a protector\n
		of the SACRED BLADE?!\p
		Here. This TOTODILE is special.\n
		It has the KNIGHT's will required\l
		to wield the SACRED BLADE.", MSGBOX_AUTOCLOSE)
	waitmessage
	givemon(SPECIES_TOTODILE_PARTNER, 100)
	setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_TOTODILE)
    if(var(VAR_RESULT) == MON_GIVEN_TO_PARTY){
        playfanfare(MUS_OBTAIN_ITEM)
        msgbox("{PLAYER} received TOTODILE!")
		waitmessage
        setflag(FLAG_RECEIVED_TOTODILE_PARTNER)
    }
    elif(var(VAR_RESULT) == MON_GIVEN_TO_PC){
        playfanfare(MUS_OBTAIN_ITEM)
        msgbox("{PLAYER} received TOTODILE!\n
			TOTODILE was sent to the PC.")
		waitmessage
        setflag(FLAG_RECEIVED_TOTODILE_PARTNER)
    }
    else{
        goto(Common_EventScript_NoMoreRoomForPokemon)
    }
	msgbox("Okay!\n
		I need to get back to my training!\p
		{PLAYER}, if you're going to see MOMO,\n
		can you tell her I'm gonna train for\l
		a while longer?", MSGBOX_AUTOCLOSE)
	waitmessage
	setobjectnewmovementtype(21, MOVEMENT_TYPE_WALK_IN_PLACE_DOWN)
	applymovement(21, Common_Movement_WalkInPlaceDown)
	waitmovement(21)
	goto_if_eq(VAR_GYM_LEADER_COUNT, 9, EventScript_UnlockEliteFourFinalRematch)
	release
	end
}

script MossdeepCity_EventScript_GiveTotodile{
	lock
    getobjectfacingdirection(OBJ_EVENT_ID_PLAYER, VAR_TEMP_1)
    playbgm(MUS_NONE, FALSE)
    delay(20)
    playse(SE_M_DOUBLE_TEAM)
    waitse
    playmoncry(SPECIES_ETERNATUS, CRY_MODE_NORMAL)
    msgbox("ARGH!\n
        AAAARGH!", MSGBOX_AUTOCLOSE)
    waitmessage
    waitmoncry
    playse(SE_PIN)
    applymovement(21, Common_Movement_ExclamationMark)
    waitmovement(21)
    waitse
	setobjectnewmovementtype(21, MOVEMENT_TYPE_NONE)
    applymovement(21, Common_Movement_FacePlayer)
    waitmovement(21)
    delay(40)
    //playse(SE_M_YAWN)
	playmoncry(SPECIES_TERAPAGOS, CRY_MODE_NORMAL)
    call(ShoalCave_LowTideIceRoom_EventScript_AriaPosition1)
    waitmovement(21)
    msgbox("AH!", MSGBOX_AUTOCLOSE)
    waitmessage
	waitmoncry
    fadedefaultbgm
    call(ShoalCave_LowTideIceRoom_EventScript_AriaPosition2)
    waitmovement(21)
	msgbox("{PLAYER}!\n
		You scared me again!", MSGBOX_DEFAULT)
	waitmessage
	checkitem(ITEM_SACRED_BLADE)
	goto_if_eq(VAR_RESULT, TRUE, MossdeepCity_EventScript_GiveTotodilePostBattle)
	closemessage
	setobjectnewmovementtype(21, MOVEMENT_TYPE_WALK_IN_PLACE_DOWN)
	applymovement(21, Common_Movement_WalkInPlaceDown)
	waitmovement(21)
	goto_if_eq(VAR_GYM_LEADER_COUNT, 9, EventScript_UnlockEliteFourFinalRematch) // should be functionally unused here
	release
	end
}

script MossdeepCity_Gym_NPC{
    msgbox(MossdeepCity_Text_GymLeaderGone, MSGBOX_NPC)
    end
}

script MossdeepCity_EventScript_AriaSword{
	lockall
    playse(SE_M_DOUBLE_TEAM)
    delay(20)
    msgbox("They're swinging a sword.\n
    It looks dangerous to approach them\l
    from the front.", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkLeft)
    waitmovement(0)
    releaseall
    end
}

script MossdeepCity_EventScript_RecoverTutor{
    lock
	faceplayer
    msgbox(MossdeepCity_Text_RecoverTeach, MSGBOX_YESNO)
	waitmessage
    goto_if_eq(VAR_RESULT, NO, MoveTutor_EventScript_RecoverDeclined)
	msgbox("Which POKéMON do you want to\nteach RECOVER to?", MSGBOX_DEFAULT)
	setvar(VAR_0x8005, MOVE_RECOVER)
	call(MoveTutor_EventScript_OpenPartyMenu)
	goto_if_eq(VAR_RESULT, 0, MoveTutor_EventScript_RecoverDeclined)
	goto(MoveTutor_EventScript_RecoverTaught)
	end
}

script MoveTutor_EventScript_RecoverDeclined{
	msgbox("Well, alright.\n
		Don't overexert yourself.", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

script MoveTutor_EventScript_RecoverTaught{
	msgbox("All right.\p
		Come back if you ever need to recover\n
		from your training.", MSGBOX_AUTOCLOSE)
	waitmessage
	release
	end
}

text MossdeepCity_Text_RecoverTeach{
	"Pfft. Those meatheads on the beach\n
	spend all day training.\p
	Giving your muscles time to recover is\n
	is important too.\p
	If you want, I could teach your POKéMON\n
	how to RECOVER."
}

text MossdeepCity_Text_GymLeaderGone{
    "Well met, challenger. Here to take on\n
    the GYM, I presume.\p
    The KNIGHT commander has left with their\n
    Order to train in SHOAL CAVE.\p
    You'll have to wait until they return,\n
    unless you're brave enough to go\l
	get them yourself…"
}

movement MossdeepCity_Movement_MomoClone{
	walk_fast_down
	walk_fast_left
}

movement MossdeepCity_Movement_MomoClone2{
	walk_fast_down
	walk_fast_left
	walk_in_place_right
}

script MossdeepCity_EventScript_PunchesTutor{
	lock
	faceplayer
	msgbox("They called me the fisting avatar in my\n
		prime because of my elemental fists.\p
		I can teach your POKéMON how to\n
		fist too, if you'd like.", MSGBOX_YESNO)
	waitmessage
	goto_if_eq(VAR_RESULT, YES, MossdeepCity_EventScript_PunchesTutorChoices)
	goto(MossdeepCity_EventScript_PunchesTutorDecline)
	release
	end
}

script MossdeepCity_EventScript_PunchesTutorChoices{
	lock
	msgbox("Which punch do you want me\nto teach?", MSGBOX_DEFAULT)
	dynmultichoice(0,0, FALSE, 6, 0, DYN_MULTICHOICE_CB_NONE, "FIRE PUNCH", "ICE PUNCH", "THUNDER PUNCH", "BULLET PUNCH", "SUCKER PUNCH")
	switch (var(VAR_RESULT)) {
		case 0:
			goto(MoveTutor_EventScript_FirePunchTeach)
		case 1:
			goto(MoveTutor_EventScript_IcePunchTeach)
		case 2:
			goto(MoveTutor_EventScript_ThunderPunchTeach)
		case 3:
			goto(MoveTutor_EventScript_BulletPunchTeach)
		case 4:
			goto(MoveTutor_EventScript_SuckerPunchTeach)
		case MULTI_B_PRESSED:
			goto(MossdeepCity_EventScript_PunchesTutorDecline)
		default:
			goto(MossdeepCity_EventScript_PunchesTutorDecline)
	}
	end
}

script MoveTutor_EventScript_FirePunchTeach{
	msgbox("Which POKéMON do you want to\nteach FIRE PUNCH to?", MSGBOX_DEFAULT)
	setvar(VAR_0x8005, MOVE_FIRE_PUNCH)
	call(MoveTutor_EventScript_OpenPartyMenu)
	goto_if_eq(VAR_RESULT, 0, MossdeepCity_EventScript_PunchesTutorDecline)
	goto(MossdeepCity_EventScript_PunchesTutorTaught)
	end
}


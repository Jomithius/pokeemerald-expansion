mapscripts RatCave_Central_MapScripts {}

script RatCave_Central_EventScript_Camper{
    msgbox(RatCave_Central_Text_Camper, MSGBOX_NPC)
    end
}

text RatCave_Central_Text_Camper{
    "This cave system looks like it was recently\n
    excavated…\p
    But whoever made it did a fantastic\n
    job at constructing it.\p
    They must be a genius."
}

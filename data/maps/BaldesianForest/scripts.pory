const LOCALID_LANDORUS = 1
const LOCALID_THUNDURUS = 2
const LOCALID_TORNADUS = 3
const LOCALID_ENAMORUS = 4

mapscripts BaldesianForest_MapScripts {
    MAP_SCRIPT_ON_RESUME: BaldesianForest_OnResume
    MAP_SCRIPT_ON_TRANSITION: BaldesianForest_OnTransition
}

script BaldesianForest_OnTransition{
    clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
    end
}

script BaldesianForest_OnResume{
    call_if_set(FLAG_SYS_CTRL_OBJ_DELETE, BaldesianForest_TryRemoveLegendary)
    end
}

script BaldesianForest_TryRemoveLegendary{
    specialvar(VAR_RESULT, GetBattleOutcome)
    if(var(VAR_RESULT) == B_OUTCOME_CAUGHT || var(VAR_RESULT) == B_OUTCOME_WON){
        if(var(VAR_LAST_TALKED) == LOCALID_LANDORUS 
        || var(VAR_LAST_TALKED) == LOCALID_THUNDURUS 
        || var(VAR_LAST_TALKED) == LOCALID_TORNADUS 
        || var(VAR_LAST_TALKED) == LOCALID_ENAMORUS){
            removeobject(VAR_LAST_TALKED)
            clearflag(FLAG_SYS_CTRL_OBJ_DELETE) 
        }
        else{
            clearflag(FLAG_SYS_CTRL_OBJ_DELETE) 
        }
    }
    clearflag(FLAG_SYS_CTRL_OBJ_DELETE) 
    return     
}

script BaldesianForest_EventScript_Masato{
    trainerbattle_single(TRAINER_MASATO, "Time to show the results of\nmy training!", "Those were poor results…")
    msgbox("I love training!", MSGBOX_NPC)
	end
}

script BaldesianForest_EventScript_Kamiko{
    trainerbattle_single(TRAINER_KAMIKO, "I just love a stroll through the forest!", "Aw, I lost…")
    msgbox("I just love a stroll through the forest!", MSGBOX_NPC)
	end
}


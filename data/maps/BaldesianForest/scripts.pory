script BaldesianForest_EventScript_Landorus{
    lock
    faceplayer
    setflag(FLAG_SYS_CTRL_OBJ_DELETE)
    playmoncry(SPECIES_LANDORUS, CRY_MODE_ENCOUNTER)
    waitmoncry
    setwildbattle(SPECIES_LANDORUS, 75)
    special(BattleSetup_StartLegendaryBattle)
    waitstate
	release
	end
}


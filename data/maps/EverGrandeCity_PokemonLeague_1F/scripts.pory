script EverGrandeCity_PokemonLeague_1F_EventScript_FinalWarning{
	lockall
	msgbox("{COLOR RED}{SHADOW LIGHT_RED}WARNING\p
		{COLOR BLUE}{SHADOW LIGHT_BLUE}Once you enter, there's no\n
		going back.\p
		Make sure you're ready.", MSGBOX_AUTOCLOSE)
	waitmessage
	setvar(VAR_FINAL_REMATCH_STATE, 6)
	releaseall
	end
}

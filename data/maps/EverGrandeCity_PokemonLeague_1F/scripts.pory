    faceplayer
    message(gText_HowMayIServeYou)
	waitmessage
	pokemart(EverGrandeCity_PokemonLeague_1F_MegaStonePokemart)
	msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)

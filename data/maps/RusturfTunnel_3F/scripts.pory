mapscripts RusturfTunnel_3F_MapScripts {}

script RusturfTunnel_3F_EventScript_DefogMan{
    lock
    faceplayer
    if(flag(FLAG_RECEIVED_TM_DEFOG) == TRUE){
        msgbox("Huh?\n
            “Why is it still foggy in here?”\p
            Like, this isn't fog, dude!", MSGBOX_NPC)
        waitmessage
    }
    else{
        msgbox("Dude, if you gotta like, air a room\n
        out quick, you can use this.", MSGBOX_DEFAULT)
        waitmessage
        giveitem(ITEM_TM_DEFOG)
        waitmessage
        msgbox("DEFOG doesn't only clear hazards, it\n
        also like, lowers the foe's evasion.", MSGBOX_NPC)
        waitmessage
        setflag(FLAG_RECEIVED_TM_DEFOG)
    }
    release
    end
}

script RusturfTunnel_3F_EventScript_Sarah{
	trainerbattle_single(TRAINER_SARAH, RusturfTunnel_3F_Text_SarahIntro, RusturfTunnel_3F_Text_SarahDefeat)
    msgbox(RusturfTunnel_3F_Text_SarahPostBattle, MSGBOX_NPC)
	end
}

text RusturfTunnel_3F_Text_SarahIntro{
	"Do you smell that?"
}

text RusturfTunnel_3F_Text_SarahDefeat{
	"Oh, my goodness."
}

text RusturfTunnel_3F_Text_SarahPostBattle{
	"Seriously, what's that smell?"
}

script RusturfTunnel_3F_EventScript_Dawson{

}

text RusturfTunnel_3F_Text_DawsonIntro{
	"Huh? I don't smell anything."
}

text RusturfTunnel_3F_Text_DawsonDefeat{
	"I really don't smell anything!"
}

text RusturfTunnel_3F_Text_DawsonPostBattle{
	"Does it really smell bad?"
}


script Route135_EventScript_WomanILoveLechonk{
    lock
    faceplayer
    msgbox("I just love LECHONK!", MSGBOX_DEFAULT)
    dynmultichoice(0,0, TRUE, 6, 0, DYN_MULTICHOICE_CB_NONE, "Me too!", "Yup. They make good bacon.")
    if(var(VAR_RESULT) == 0){
        msgbox("Right?!\n
            They're stinky, but sooo cute!", MSGBOX_AUTOCLOSE)
    }
    else{
        msgbox("What's WRONG with you?!\n
            I'm vegan, you PIG!", MSGBOX_AUTOCLOSE)
    }
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}

script Route135_EventScript_WomanILoveMiltank{
    lock
    faceplayer
    msgbox("I just love MILTANK!", MSGBOX_DEFAULT)
    dynmultichoice(0,0, TRUE, 6, 0, DYN_MULTICHOICE_CB_NONE, "Me too!", "Yup. They make good burgers.")
    if(var(VAR_RESULT) == 0){
        msgbox("Right?!\n
            They're stinky, but sooo cute!", MSGBOX_AUTOCLOSE)
    }
    else{
        msgbox("What's WRONG with you?!\n
            I'm vegan, you COW!", MSGBOX_AUTOCLOSE)
    }
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}

script Route135_EventScript_FirstMoo{
    lockall
    applymovement(26, Common_Movement_WalkInPlaceDown)
    waitmovement(26)
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceUp)
    waitmovement(0)
    msgbox("You're just in time!\n
        That MILTANK found it's moo!\p
        Listen!", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(26, Common_Movement_WalkInPlaceLeft)
    waitmovement(26)
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceLeft)
    waitmovement(0)
    fadeoutbgm(1)
    delay(60)
    playmoncry(SPECIES_MILTANK, CRY_MODE_NORMAL)
    msgbox("MILTANK: Moooooo!", MSGBOX_AUTOCLOSE)
    waitmoncry
    waitmessage
    applymovement(26, Common_Movement_WalkInPlaceDown)
    waitmovement(26)
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceUp)
    waitmovement(0)
    msgbox("Isn't it beautiful?\n
        Gosh, I love nature.", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(26, Common_Movement_WalkInPlaceLeft)
    waitmovement(26)
    setvar(VAR_TEMP_7, 1)
    fadeinbgm(1)
    releaseall
    end
}


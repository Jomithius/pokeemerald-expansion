mapscripts Route135_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: Route135_OnTransition
}

script Route135_OnTransition{
    setflag(FLAG_ENABLED_JAMES_MATCH_CALL)
    setflag(FLAG_SYS_DYNAMIC_LEVELS)
    #call(Route135_CheckEnterFromLab) // now handled in GetCurrLocationDefaultMusic();.
    #clearflag(FLAG_DONT_TRANSITION_MUSIC)
    end
}

// unused
script Route135_CheckEnterFromLab{
    getplayerxy(VAR_TEMP_0, VAR_TEMP_1)
    call_if_le(VAR_TEMP_0, 8, Route135_EnteredFromLab)
    return
}

// unused
script Route135_EnteredFromLab{
    savebgm(MUS_ETERNA_CITY_NIGHT)
    return
}

//unused
script Route135_TryUpdateMusic{
    specialvar(VAR_RESULT, GetPlayerFacingDirection)
    goto_if_eq(VAR_RESULT, DIR_EAST, Route135_UpdateMusicLushAcreage)
    goto_if_eq(VAR_RESULT, DIR_NORTH, Route135_UpdateMusicLushAcreage)
    goto_if_eq(VAR_RESULT, DIR_WEST, Route135_UpdateDefaultMusic)
    goto_if_eq(VAR_RESULT, DIR_SOUTH, Route135_UpdateDefaultMusic)
    end
}

script Route135_UpdateMusicLushAcreage{
    fadenewbgm(MUS_ETERNA_CITY_NIGHT)
    savebgm(MUS_ETERNA_CITY_NIGHT)
    end
}

script Route135_UpdateDefaultMusic{
    fadedefaultbgm
    savebgm(MUS_ROWANS_LAB)
    end
}

script Route135_EventScript_Danny{
    trainerbattle_single(TRAINER_DANNY, "Hey!\nDoesn't this POKéMON sound weird?", "I've never heard a POKéMON like that!")
    msgbox("I've heard seen a POKéMON like that!", MSGBOX_NPC)
	end
}

script Route135_EventScript_Danuel{
    trainerbattle_single(TRAINER_DANUEL, "Hey!\nThis is my fishing spot!", "I guess you can fish here too.")
    msgbox("This spot is great!\p
        It feels like there's rarer POKéMON\n
        right here!", MSGBOX_NPC)
	end
}

script Route135_EventScript_Pibbles{
    trainerbattle_single(TRAINER_PIBBLES, "I love nature!", "I don't love battling.")
    msgbox("I love how rural it is out here.\n
        Nature is so beautiful.", MSGBOX_NPC)
	end
}

script Route135_EventScript_Billiam{
    trainerbattle_single(TRAINER_BILLIAM, "It's my job to train POKéMON out here!", "Thanks for helping!")
    msgbox("I was lucky enough to get a job\n
        at the ranch.\p
        Oh, sorry.\n
        Do you even know what a job is?", MSGBOX_NPC)
	end
}

script Route135_EventScript_Denjamin{
    trainerbattle_single(TRAINER_DENJAMIN, "I'm on break right now.\nLet's kill time with a battle!", "I don't want to get back to work.")
    msgbox("It's hard work out here, but the\n
        pay is surprisingly good.", MSGBOX_NPC)
	end
}

script Route135_EventScript_Whitney{
    goto_if_not_defeated(TRAINER_WHITNEY, Route135_EventScript_WhitneyBattle)
    goto_if_unset(FLAG_RECEIVED_MILTANKITE, Route135_EventScript_GiveMiltankite)
    msgbox("I'm so bored!\p
        I want to go back to GOLDENROD\n
        CITY already!", MSGBOX_NPC)
	end
}

script Route135_EventScript_WhitneyBattle{
    lock
    msgbox("Gosh, it's so boring out here!\n
        Why did we have to visit our family\l
        out in HOENN's countryside…", MSGBOX_AUTOCLOSE)
    waitmessage
    playse(SE_PIN)
    applymovement(VAR_LAST_TALKED, Common_Movement_ExclamationMark)
    waitmovement(0)
    waitse
    faceplayer
    playbgm(MUS_ENCOUNTER_GIRL, FALSE)
    msgbox("Huh? Who are you?\n
        A TRAINER?\p
        Perfect timing!\n
        Help me have some fun with a battle!", MSGBOX_AUTOCLOSE)
    waitmessage
    setflag(FLAG_SYS_BOSS_BATTLE)
    trainerbattle_no_intro(TRAINER_WHITNEY, "That was fun!")
    clearflag(FLAG_SYS_BOSS_BATTLE)
    goto(Route135_EventScript_GiveMiltankite)
    end
}

script Route135_EventScript_GiveMiltankite{
    lock
    faceplayer
    msgbox("That was a lot of fun!\n
        Did my MILTANK surprise you? Hehe!\p
        Here. I have an extra stone you can\n
        have as thanks for entertaining me!", MSGBOX_DEFAULT)
    waitmessage
    checkitemspace(ITEM_MILTANKITE)
    goto_if_eq(VAR_RESULT, FALSE, Common_EventScript_ShowBagIsFull)
    giveitem(ITEM_MILTANKITE)
    setflag(FLAG_RECEIVED_MILTANKITE)
    waitmessage
    msgbox("I hope I can go back to GOLDENROD\n
        CITY soon.\p
        I want to go shopping at the DEPT.\n
        STORE!", MSGBOX_AUTOCLOSE)
    waitmessage
    release
    end
}

script Route135_EventScript_MoomooMilkSalesman{
    lock
    faceplayer
    message("Welcome, partner!\n
        Take a gander at my wares.")
	waitmessage
	pokemart(Route135_Pokemart)
	msgbox("Pleasure doin' business!", MSGBOX_DEFAULT)
	release
	end
}

mart Route135_Pokemart{
    ITEM_MOOMOO_MILK
    ITEM_BERRY_JUICE
}



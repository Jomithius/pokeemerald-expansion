script Route137_EventScript_Beauty{
    lock
    faceplayer
    msgbox("Those guys next to me just keep saying\n
        “Yeeeaaaaheheeaaahhh…”\p
        Are they okay?", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}

script Route137_EventScript_Sailor1{
    lock
    faceplayer
    msgbox("Huh?\n
        … … … …\p
        How did we get this ship in here with\n
        all these rocks?\p
        … You ask too many questions.", MSGBOX_AUTOCLOSE)
    waitmessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release
    end
}

script Route137_EventScript_Sailor2{
    msgbox("Hm…\p
        That cave wasn't there the\n

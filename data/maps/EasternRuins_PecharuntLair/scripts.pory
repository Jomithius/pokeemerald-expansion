script EasternRuins_PecharuntLair_EventScript_Ogerpon{
    lock
    faceplayer
    playmoncry(SPECIES_OGERPON, CRY_MODE_ENCOUNTER)
    waitmoncry
    setwildbattle(SPECIES_OGERPON, 75)
